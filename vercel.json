{
  "cleanUrls": true,
  "routes": [
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/index",
      "dest": "/index.html"
    },
    {
      "src": "/esthelabs",
      "dest": "/presentation.html"
    },
    {
      "src": "/((?!style|sunum|supabase|assets|favicon|apple-touch|site|web-app).*)",
      "dest": "/presentation.html"
    }
  ]
}